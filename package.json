{
  "name": "nuxt3-template",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "sass-migrate": "sass-migrator module --migrate-deps app/assets/scss/base.scss",
    "code:format": "eslint --fix .",
    "code:lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "nitro task run db:migrate"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/eslint-config": "1.15.2",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/image": "2.0.0",
    "@nuxt/kit": "4.4.2",
    "@nuxt/typescript-build": "3.0.2",
    "@nuxt/typescript-runtime": "3.0.2",
    "@nuxt/ui": "4.6.1",
    "@nuxtjs/i18n": "10.2.4",
    "@nuxtjs/seo": "5.1.3",
    "@pinia/nuxt": "0.11.3",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/vite": "4.2.2",
    "@types/js-yaml": "4.0.9",
    "eslint": "10.2.0",
    "husky": "9.1.7",
    "js-yaml": "4.1.1",
    "nuxt": "4.4.2",
    "nuxt-auth-utils": "0.5.29",
    "nuxt-security": "2.5.1",
    "pinia": "3.0.4",
    "postcss": "8.5.9",
    "postcss-loader": "8.2.1",
    "sass": "1.99.0",
    "sass-loader": "16.0.7",
    "sass-migrator": "2.5.7",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite-plugin-vue-tracer": "1.3.0",
    "vue": "3.5.32",
    "vue-router": "5.0.4",
    "vue-tsc": "3.2.6"
  },
  "dependencies": {
    "@sentry/browser": "^10.48.0",
    "@sentry/node": "^10.48.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "12.9.0",
    "consola": "^3.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "h3-zod": "^0.5.3",
    "node-gyp": "^12.2.0",
    "zod": "^4.3.6"
  },
  "onlyBuiltDependencies": [
    "sqlite3",
    "better-sqlite3",
    "esbuild",
    "sharp",
    "vue-demi"
  ],
  "pnpm": {
    "overrides": {
      "@vercel/nft": "^0.27.4"
    }
  }
}