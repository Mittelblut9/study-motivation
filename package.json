{
  "name": "nuxt3-template",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "sass-migrate": "sass-migrator module --migrate-deps app/assets/scss/base.scss",
    "code:format": "eslint --fix .",
    "code:lint": "eslint .",
    "scripts:install": "node scripts/_install/install.js"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/eslint-config": "1.15.2",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/image": "2.0.0",
    "@nuxt/kit": "4.4.2",
    "@nuxt/typescript-build": "3.0.2",
    "@nuxt/typescript-runtime": "3.0.2",
    "@nuxt/ui": "4.6.0",
    "@nuxtjs/i18n": "10.2.1",
    "@nuxtjs/seo": "5.1.2",
    "@pinia/nuxt": "0.11.3",
    "@sentry/nuxt": "10.47.0",
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/vite": "4.2.1",
    "@types/js-yaml": "4.0.9",
    "eslint": "9.39.1",
    "husky": "9.1.7",
    "js-yaml": "4.1.1",
    "nuxt": "4.4.2",
    "pinia": "3.0.4",
    "postcss": "8.5.6",
    "postcss-loader": "8.2.0",
    "sass": "1.99.0",
    "sass-loader": "16.0.6",
    "sass-migrator": "2.5.6",
    "tailwindcss": "4.2.1",
    "typescript": "6.0.2",
    "vite-plugin-vue-tracer": "1.3.0",
    "vue": "3.5.24",
    "vue-router": "5.0.3",
    "vue-tsc": "3.2.2"
  }
}